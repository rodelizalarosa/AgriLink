{
  "version": 8,
  "name": "AgriLink Premium Theme",
  "sources": {
    "composite": {
      "url": "mapbox://mapbox.mapbox-streets-v8",
      "type": "vector"
    }
  },
  "sprite": "mapbox://sprites/mapbox/light-v10",
  "glyphs": "mapbox://fonts/mapbox/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f2f5f1"
      }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "composite",
      "source-layer": "landuse",
      "paint": {
        "fill-color": [
          "match",
          ["get", "class"],
          "park", "#d2e6c8",
          "agriculture", "#e1ecd9",
          "forest", "#c3deb8",
          "grass", "#d2e6c8",
          "wood", "#c3deb8",
          "#f2f5f1"
        ],
        "fill-opacity": 0.8
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "composite",
      "source-layer": "water",
      "paint": {
        "fill-color": "#b1cbe3"
      }
    },
    {
      "id": "building",
      "minzoom": 14.5,
      "type": "fill",
      "source": "composite",
      "source-layer": "building",
      "paint": {
        "fill-color": "#e2e6e1",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "building-label",
      "minzoom": 15.5,
      "type": "symbol",
      "source": "composite",
      "source-layer": "building",
      "filter": ["has", "name"],
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Open Sans Regular", "Arial Unicode MS Regular"],
        "text-size": 10,
        "text-max-width": 5
      },
      "paint": {
        "text-color": "#94a394",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.5,
        "text-halo-blur": 1
      }
    },
    {
      "id": "road-simple",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "paint": {
        "line-color": "#ffffff",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          5, 0.5,
          15, 3.5
        ]
      }
    },
    {
      "id": "road-major",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "filter": ["in", "class", "primary", "secondary", "tertiary", "motorway", "trunk"],
      "paint": {
        "line-color": [
          "match",
          ["get", "class"],
          ["motorway", "trunk", "primary"], "#fcf8eb",
          "#ffffff"
        ],
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          5, 1,
          15, [
            "match",
            ["get", "class"],
            ["motorway", "trunk", "primary"], 6.5,
            5
          ]
        ]
      }
    },
    {
      "id": "road-label",
      "type": "symbol",
      "source": "composite",
      "source-layer": "road",
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Open Sans Regular", "Arial Unicode MS Regular"],
        "text-size": 11,
        "symbol-placement": "line",
        "text-anchor": "center"
      },
      "paint": {
        "text-color": "#a3b3a3",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2,
        "text-halo-blur": 1
      }
    },
    {
      "id": "place-labels",
      "type": "symbol",
      "source": "composite",
      "source-layer": "place_label",
      "layout": {
        "text-field": ["get", "name_en"],
        "text-font": ["Open Sans Bold", "Arial Unicode MS Bold"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          3, 10,
          12, 18
        ]
      },
      "paint": {
        "text-color": "#283b1d",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2.5,
        "text-halo-blur": 2
      }
    },
    {
      "id": "poi-labels",
      "type": "symbol",
      "source": "composite",
      "source-layer": "poi_label",
      "layout": {
        "icon-image": ["concat", ["get", "maki"], "-15"],
        "icon-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          12, 0.8,
          16, 1.2
        ],
        "text-field": ["get", "name_en"],
        "text-font": ["Open Sans Semibold", "Arial Unicode MS Bold"],
        "text-size": 11,
        "text-offset": [0, 0.8],
        "text-anchor": "top"
      },
      "paint": {
        "text-color": "#4d732c",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2,
        "text-halo-blur": 1
      }
    }
  ]
}
